{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AMORA",
  "version": "0.1.0",
  "identifier": "com.amora.rpg",
  "build": {
    "frontendDist": "../../static",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "AMORA",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "createUpdaterArtifacts": true,
    "resources": {
      "resources/backend/": "backend/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["French"],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdDQ0E3RDEzMDIzRTQ5MzkKUldRNVNUNENFMzNLZkJKOEtMdnc5V1BOMklTMWlpQmFRMzdQdEJESEdObnZTckJWQklZMkcrVmoK",
      "endpoints": [
        "https://github.com/Jedanns/amora/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
